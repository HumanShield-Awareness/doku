# Security- und Cache-Header fuer Cloudflare Pages.
# NICHT ohne Ruecksprache aendern (siehe CLAUDE.md).
# CSP-Hinweise:
# - 'unsafe-inline' in script-src: Starlight injiziert ein Inline-Skript fuer
#   den Dark-Mode (Theme-Persistenz vor dem ersten Paint).
# - 'wasm-unsafe-eval': Pagefind (Starlight-Suche) laedt WebAssembly.
# Bei neuen externen Skripten CSP gezielt erweitern, nicht pauschal oeffnen.

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()

# Astro-Assets sind inhaltsgehasht -> dauerhaft cachebar
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Pagefind-Suchindex aendert sich mit jedem Build
/pagefind/*
  Cache-Control: public, max-age=3600
